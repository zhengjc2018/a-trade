# a-trade 环境变量模板
# 复制为 .env 并填入真实值，.env 不会进 git

# === OpenClaw / QQ 官方机器人 ===
QQ_BOT_APPID=your_appid_here
QQ_BOT_APPSECRET=your_appsecret_here
QQ_BOT_QQ=your_bot_qq_number
QQ_TARGET_GROUP=your_target_group_number

# === 钉钉群自定义机器人 ===
DINGTALK_ACCESS_TOKEN=your_dingtalk_access_token_here
DINGTALK_KEYWORD=股票
# 机器人启用“加签”安全设置时填写
DINGTALK_SECRET=
DINGTALK_AT_ALL=false
